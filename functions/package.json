{
  "name": "functions",
  "version": "1.0.0",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/server.ts",
    "start:server": "node lib/server.js",
    "test": "jest --config jest.config.ts",
    "serve": "yarn build && firebase emulators:start --only functions",
