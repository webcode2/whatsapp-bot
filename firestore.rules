rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    // For now, all access is backend-only (no direct FlutterFlow Firestore reads).
    // Cloud Functions run as the default service account and bypass these rules entirely.
    // When FlutterFlow is integrated, add per-user rules below.
    function isBackendRequest() {
      // Deny all client requests by default until FlutterFlow requires access.
      return false;
    }

    // ── users/{phone} ──────────────────────────────────────────────────────────
    match /users/{phone} {
      allow read, write: if isBackendRequest();
      
      match /journal/{date} {
        allow read, write: if isBackendRequest();
      }
      match /declarations/{date} {
        allow read, write: if isBackendRequest();
      }
      match /questLog/{date} {
        allow read, write: if isBackendRequest();
      }
    }

    // ── prayerCards/{cardId} ───────────────────────────────────────────────────
    match /prayerCards/{cardId} {
      allow read: if isBackendRequest();
      allow write: if false; // seeded via admin SDK only
    }

    // ── prayerThemes/{themeId} ─────────────────────────────────────────────────
    match /prayerThemes/{themeId} {
      allow read: if isBackendRequest();
      allow write: if false;

      match /prayers/{prayerId} {
        allow read: if isBackendRequest();
        allow write: if false;
      }
    }

    // ── questContent/{weekNumber} ──────────────────────────────────────────────
    match /questContent/{weekNumber} {
      allow read: if isBackendRequest();
      allow write: if false;
    }

    // ── milestones/{milestoneId} ───────────────────────────────────────────────
    match /milestones/{milestoneId} {
      allow read: if isBackendRequest();
      allow write: if false;
    }

    // ── deliveryLogs/{logId} ───────────────────────────────────────────────────
    match /deliveryLogs/{logId} {
      allow read, write: if isBackendRequest();
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
