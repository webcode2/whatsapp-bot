FROM node:20-alpine

# Install bash for debugging convenience
RUN apk add --no-cache bash

WORKDIR /app

# Copy package files and install dependencies
COPY functions/package.json functions/yarn.lock* ./
RUN yarn install

# Copy source
COPY functions/ ./

EXPOSE 3000

# Default: run dev server with ts-node (hot typechecking)
CMD ["yarn", "dev"]
